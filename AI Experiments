    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Video demo section fade in on scroll
        const demoSection = document.querySelector('.demo-section');
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver(function(entries) {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        if (demoSection) {
            observer.observe(demoSection);
        }

        // Payment method selection
        document.querySelectorAll('[data-payment]').forEach(option => {
            option.addEventListener('change', function() {
                document.querySelectorAll('[data-payment]').forEach(o => {
                    o.classList.remove('selected');
                    const detail = document.querySelector(`#${o.id}Details`);
                    if (detail) detail.classList.remove('active');
                });
                this.classList.add('selected');
                const detailId = this.getAttribute('data-payment') + 'Details';
                const detail = document.getElementById(detailId);
                if (detail) detail.classList.add('active');
            });
        });

        // Shipping selection
        document.querySelectorAll('[data-shipping]').forEach(option => {
            option.addEventListener('change', function() {
                document.querySelectorAll('[data-shipping]').forEach(o => o.classList.remove('selected'));
                this.classList.add('selected');
                updateTotal();
            });
        });

        // Coupon toggle
        document.getElementById('couponToggle')?.addEventListener('click', function() {
            const section = document.getElementById('couponSection');
            const chevron = document.getElementById('couponChevron');
            section.classList.toggle('active');
            chevron.style.transform = section.classList.contains('active') ? 'rotate(180deg)' : 'rotate(0deg)';
        });

        function updateTotal() {
            // Calculate total based on shipping selection
            const selectedShipping = document.querySelector('[data-shipping].selected');
            const shippingCost = parseFloat(selectedShipping?.getAttribute('data-shipping') || 0);
            const subtotal = 99.99;
            const tax = 8.00;
            const total = subtotal + shippingCost + tax;
            
            document.getElementById('shippingCost').textContent = shippingCost > 0 ? `$${shippingCost.toFixed(2)}` : 'Free';
            document.getElementById('totalAmount').textContent = `$${total.toFixed(2)}`;
        }
    </script>
