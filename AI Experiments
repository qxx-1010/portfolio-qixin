                paymentOptions.forEach(opt => {
                    opt.classList.remove('selected');
                    const circle = opt.querySelector('.rounded-full');
                    circle.classList.remove('border-black');
                    circle.classList.add('border-gray-light');
                    const dot = circle.querySelector('div');
                    dot.style.opacity = '0';
                    dot.style.transform = 'scale(0)';
                });

                option.classList.add('selected');
                const circle = option.querySelector('.rounded-full');
                circle.classList.remove('border-gray-light');
                circle.classList.add('border-black');
                const dot = circle.querySelector('div');
                setTimeout(() => {
                    dot.style.opacity = '1';
                    dot.style.transform = 'scale(1)';
                }, 50);

                // Show/hide card details
                const paymentType = option.dataset.payment;
                if (paymentType === 'card') {
                    cardDetails.classList.add('active');
                } else {
                    cardDetails.classList.remove('active');
                }
            });
        });

        // Card number formatting
        document.getElementById('cardNumber').addEventListener('input', (e) => {
            let value = e.target.value.replace(/\s/g, '').replace(/\D/g, '');
            let formatted = value.match(/.{1,4}/g)?.join(' ') || '';
            e.target.value = formatted;

            // Validate and show checkmark
            const validIcon = e.target.parentElement.querySelector('.valid-icon');
            if (value.length === 16) {
                if (validIcon) {
                    validIcon.style.opacity = '1';
                    validIcon.style.transform = 'scale(1) translateY(-50%)';
                }
            } else {
                if (validIcon) {
                    validIcon.style.opacity = '0';
                    validIcon.style.transform = 'scale(0) translateY(-50%)';
                }
            }
        });

        // Expiry date formatting
        document.getElementById('expiry').addEventListener('input', (e) => {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length >= 2) {
                value = value.slice(0, 2) + '/' + value.slice(2, 4);
            }
            e.target.value = value;
        });

        // CVV formatting
        document.getElementById('cvv').addEventListener('input', (e) => {
            e.target.value = e.target.value.replace(/\D/g, '');
        });

        // Coupon toggle with enhanced animation
        couponToggle.addEventListener('click', () => {
            const isActive = couponSection.classList.toggle('active');
            couponChevron.style.transform = isActive ? 'rotate(180deg)' : 'rotate(0)';

            if (isActive) {
                setTimeout(() => {
                    couponCodeInput.focus();
                }, 300);
            }
        });

        // Coupon code input
        couponCodeInput.addEventListener('input', () => {
            applyCouponBtn.disabled = couponCodeInput.value.trim().length === 0;
        });

        // Apply coupon with animation
        applyCouponBtn.addEventListener('click', () => {
            const code = couponCodeInput.value.trim().toUpperCase();
            if (code === 'SAVE10') {
                couponMessage.textContent = 'Coupon applied! 10% off your order.';
                couponMessage.classList.remove('hidden', 'text-error');
                couponMessage.classList.add('text-success', 'animate-slide-left');
                applyCouponBtn.disabled = true;
                applyCouponBtn.textContent = 'Applied';

                // Trigger confetti
                createConfetti();
            } else {
                couponMessage.textContent = 'Invalid coupon code.';
                couponMessage.classList.remove('hidden', 'text-success');
                couponMessage.classList.add('text-error', 'animate-shake');
                applyCouponBtn.classList.add('animate-shake');
                setTimeout(() => {
                    applyCouponBtn.classList.remove('animate-shake');
                }, 500);
            }
            setTimeout(() => {
                couponMessage.classList.add('hidden');
                couponMessage.classList.remove('animate-slide-left', 'animate-shake');
            }, 3000);
        });

        // Confetti creation
        function createConfetti() {
            const container = document.getElementById('confettiContainer');
            const colors = ['#0A0A0A', '#16A34A', '#F5A623', '#6B6B6B', '#E5E5E5'];

            for (let i = 0; i < 50; i++) {
                const confetti = document.createElement('div');
                confetti.className = 'confetti-piece';
                confetti.style.left = Math.random() * 100 + '%';
                confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                confetti.style.animationDelay = Math.random() * 0.5 + 's';
                confetti.style.animationDuration = (Math.random() * 2 + 2) + 's';
                confetti.style.borderRadius = Math.random() > 0.5 ? '50%' : '0';
                container.appendChild(confetti);

                setTimeout(() => {
                    confetti.remove();
                }, 4000);
            }
        }

        // Update totals with animation
        function updateTotals() {
            const total = subtotal + currentShipping + tax;

            // Animate shipping cost change
            if (currentShipping === 0) {
                shippingCostEl.textContent = 'Free';
            } else {
                shippingCostEl.textContent = '$' + currentShipping.toFixed(2);
            }

            // Animate total
            const currentTotal = parseFloat(totalAmountEl.textContent.replace('$', ''));
            animateNumber(totalAmountEl, total);
            animateNumber(totalMobileEl, total);
        }

        // Payment button animation
        function processPayment(button, textEl, isMobile = false) {
            // Add loading state
            button.classList.add('loading');
            textEl.classList.add('hidden');
            btnTextLoading.classList.remove('hidden');
            btnSpinner.classList.remove('hidden');

            // Simulate payment processing
            setTimeout(() => {
                // Show success state
                button.classList.remove('loading');
                button.classList.add('success');
                btnTextLoading.classList.add('hidden');
                btnSpinner.classList.add('hidden');

                if (!isMobile) {
                    successContainer.classList.remove('hidden');
                    successContainer.classList.add('animate-bounce-in');
                } else {
                    textEl.textContent = 'Success!';
                    textEl.classList.remove('hidden');
                }

                // Create confetti celebration
                createConfetti();

                setTimeout(() => {
                    alert('Payment successful! Thank you for your order.');
                }, 800);
            }, 2500);
        }

        payButton.addEventListener('click', () => processPayment(payButton, btnText, false));
        payButtonMobile.addEventListener('click', () => processPayment(payButtonMobile, btnTextMobile, true));

        // Scroll animations with Intersection Observer
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');

                    // Animate divider line when order summary is visible
                    if (entry.target.querySelector('#dividerLine')) {
                        setTimeout(() => {
                            document.getElementById('dividerLine').style.width = '100%';
                        }, 200);
                    }
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-in-section').forEach(section => {
            observer.observe(section);
        });

        // Mobile scroll effect
        window.addEventListener('scroll', () => {
            const scrolled = window.scrollY;
            const mobileCta = document.querySelector('.mobile-cta');
            if (mobileCta) {
                if (scrolled > 100) {
                    mobileCta.classList.add('shadow-lg', 'bg-white/95', 'backdrop-blur-sm');
                } else {
                    mobileCta.classList.remove('shadow-lg', 'bg-white/95', 'backdrop-blur-sm');
                }
            }
        });

        // Add ripple effect to buttons
        document.querySelectorAll('.btn-primary').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const rect = this.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                const ripple = document.createElement('span');
                ripple.style.cssText = `
                    position: absolute;
                    background: rgba(255, 255, 255, 0.3);
                    border-radius: 50%;
                    pointer-events: none;
                    width: 100px;
                    height: 100px;
                    left: ${x - 50}px;
                    top: ${y - 50}px;
                    transform: scale(0);
                    animation: ripple 0.6s linear;
                `;

                this.appendChild(ripple);

                setTimeout(() => {
                    ripple.remove();
                }, 600);
            });
        });

        // Section number pulse effect
        document.querySelectorAll('.section-number').forEach((num, index) => {
            setTimeout(() => {
                num.classList.add('pulse');
                setTimeout(() => {
                    num.classList.remove('pulse');
                }, 1500);
            }, 100 * index);
        });

        // Initialize divider animation after page load
        window.addEventListener('load', () => {
            setTimeout(() => {
                if (document.getElementById('dividerLine')) {
                    document.getElementById('dividerLine').style.width = '100%';
                }
            }, 1000);
        });
    </script>
</body>
</html>
