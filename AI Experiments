                            '100%': { transform: 'rotate(360deg)' },
                        },
                        checkDraw: {
                            '0%': { strokeDashoffset: '50', opacity: '0' },
                            '50%': { opacity: '1' },
                            '100%': { strokeDashoffset: '0', opacity: '1' },
                        },
                        expand: {
                            '0%': { maxHeight: '0', opacity: '0', transform: 'translateY(-10px)' },
                            '100%': { maxHeight: '500px', opacity: '1', transform: 'translateY(0)' },
                        },
                        pulseGlow: {
                            '0%, 100%': { boxShadow: '0 0 0 0 rgba(10, 10, 10, 0)' },
                            '50%': { boxShadow: '0 0 20px 2px rgba(10, 10, 10, 0.15)' },
