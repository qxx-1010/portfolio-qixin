        // Animated number counter
        function animateNumber(element, targetValue, prefix = '$') {
            const duration = 600;
            const startTime = performance.now();
            const startValue = 0;

            function update(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);

                // Easing function (ease-out cubic)
                const eased = 1 - Math.pow(1 - progress, 3);
                const currentValue = startValue + (targetValue - startValue) * eased;

                element.textContent = prefix + currentValue.toFixed(2);

                if (progress < 1) {
                    requestAnimationFrame(update);
                }
            }

            requestAnimationFrame(update);
        }

        // Input validation with enhanced animation
        function validateInput(input) {
            const value = input.value.trim();
            const validIcon = input.parentElement.querySelector('.valid-icon');

            if (input.validity.valid && value.length > 0) {
                input.classList.remove('invalid');
                input.classList.add('valid');
                if (validIcon) {
                    validIcon.style.opacity = '1';
                    validIcon.style.transform = 'scale(1) translateY(-50%)';
                }
                return true;
            } else if (value.length > 0) {
                input.classList.remove('valid');
                input.classList.add('invalid');
                if (validIcon) {
                    validIcon.style.opacity = '0';
                    validIcon.style.transform = 'scale(0) translateY(-50%)';
                }
                return false;
            } else {
                input.classList.remove('valid', 'invalid');
                if (validIcon) {
                    validIcon.style.opacity = '0';
                    validIcon.style.transform = 'scale(0) translateY(-50%)';
                }
                return false;
            }
        }

        // Add validation listeners
        [fullNameInput, phoneInput, addressInput, cityInput, postalCodeInput].forEach(input => {
            input.addEventListener('blur', () => validateInput(input));
            input.addEventListener('input', () => {
                if (input.classList.contains('invalid') || input.classList.contains('valid')) {
                    validateInput(input);
                }
            });
        });

        // Phone number formatting
        phoneInput.addEventListener('input', (e) => {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length > 10) value = value.slice(0, 10);
            e.target.value = value;
        });

        // Delivery option selection with enhanced animation
        deliveryOptions.forEach(option => {
            option.addEventListener('click', () => {
                deliveryOptions.forEach(opt => {
