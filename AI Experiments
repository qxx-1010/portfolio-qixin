    <!-- Confetti Container -->
    <div class="confetti-container" id="confettiContainer"></div>

    <div class="max-w-[1200px] mx-auto px-6 lg:px-12 py-12 lg:py-16">
        <!-- Header -->
        <header class="fade-in-section visible" style="transition-delay: 0ms;">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3 group cursor-pointer">
                    <div class="w-10 h-10 bg-black flex items-center justify-center transition-all duration-300 group-hover:scale-110 group-hover:rotate-3 section-icon" data-animate="true">
                        <span class="text-white font-bold text-sm">M</span>
                    </div>
                    <span class="font-semibold text-lg tracking-tight">MINIMAL</span>
                </div>
                <a href="#" class="flex items-center gap-2 text-gray hover:text-black transition-all duration-200 group">
                    <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform duration-200"></i>
                    <span class="text-sm">Back to Cart</span>
                </a>
            </div>
        </header>

        <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 mt-12">
            <!-- Left Column: Form Sections -->
            <div class="flex-1 lg:flex-[55] space-y-12">
                <!-- Shipping Address -->
                <section class="fade-in-section visible" style="transition-delay: 100ms;">
                    <h2 class="section-title text-sm font-semibold uppercase tracking-widest text-gray mb-8">
                        <div class="icon-wrapper">
                            <i data-lucide="map-pin" class="w-4 h-4"></i>
                        </div>
                        <span class="step-indicator">1</span>
                        Shipping Address
                    </h2>

                    <div class="space-y-6">
                        <!-- Full Name -->
                        <div class="relative group">
                            <input type="text" id="fullName" placeholder="Full Name" required
                                class="input-field w-full h-[52px] px-[18px] border border-border bg-white text-[15px] peer">
                            <label for="fullName" class="floating-label absolute left-[18px] top-[14px] text-[13px] uppercase tracking-wider text-gray-light bg-white px-1">
                                Full Name
                            </label>
                            <div class="valid-icon absolute right-4 top-1/2 -translate-y-1/2 opacity-0 transition-all duration-300 transform scale-0">
                                <svg class="w-5 h-5 text-success check-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                            </div>
                        </div>

                        <!-- Phone -->
                        <div class="relative">
                            <input type="tel" id="phone" placeholder="Phone Number" required
                                class="input-field w-full h-[52px] px-[18px] border border-border bg-white text-[15px] peer">
                            <label for="phone" class="floating-label absolute left-[18px] top-[14px] text-[13px] uppercase tracking-wider text-gray-light bg-white px-1">
                                Phone Number
                            </label>
                            <div class="valid-icon absolute right-4 top-1/2 -translate-y-1/2 opacity-0 transition-all duration-300 transform scale-0">
                                <svg class="w-5 h-5 text-success check-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                            </div>
                        </div>

                        <!-- Address -->
                        <div class="relative">
                            <input type="text" id="address" placeholder="Address" required
                                class="input-field w-full h-[52px] px-[18px] border border-border bg-white text-[15px] peer">
                            <label for="address" class="floating-label absolute left-[18px] top-[14px] text-[13px] uppercase tracking-wider text-gray-light bg-white px-1">
                                Address
                            </label>
                            <div class="valid-icon absolute right-4 top-1/2 -translate-y-1/2 opacity-0 transition-all duration-300 transform scale-0">
                                <svg class="w-5 h-5 text-success check-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                            </div>
                        </div>

                        <!-- City & Postal Code -->
                        <div class="grid grid-cols-2 gap-4">
                            <div class="relative">
                                <input type="text" id="city" placeholder="City" required
                                    class="input-field w-full h-[52px] px-[18px] border border-border bg-white text-[15px] peer">
                                <label for="city" class="floating-label absolute left-[18px] top-[14px] text-[13px] uppercase tracking-wider text-gray-light bg-white px-1">
                                    City
                                </label>
                                <div class="valid-icon absolute right-4 top-1/2 -translate-y-1/2 opacity-0 transition-all duration-300 transform scale-0">
                                    <svg class="w-5 h-5 text-success check-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                </div>
                            </div>
